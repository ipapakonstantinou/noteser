{
  "id": "noteser-graph",
  "name": "Graph",
  "version": "0.1.0",
  "author": "Noteser",
  "description": "Backlinks and unlinked mentions for the active note in the sidebar, plus a force-directed graph of the entire vault in a fullscreen view. Closes issue #71.",
  "main": "./main.js",
  "surfaces": {
    "sidebarPanels": [
      { "id": "graph", "title": "Graph", "icon": "link" }
    ],
    "fullscreenViews": [
      { "id": "graph", "title": "Note graph" }
    ],
    "commands": [
      { "id": "open-graph", "title": "Graph: open global graph" },
      { "id": "recompute", "title": "Graph: recompute layout" }
    ]
  },
  "permissions": [
    "vault.read.all",
    "vault.events"
  ]
}
