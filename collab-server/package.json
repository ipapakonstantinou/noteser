  },
  "dependencies": {
    "lib0": "^0.2.99",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "sharp": "^0.35.0"
  }
}
