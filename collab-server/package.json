{
  "name": "noteser-collab-server",
  "version": "0.1.0",
  "private": true,
  "description": "y-websocket-compatible live-collaboration server for noteser, running on Cloudflare Workers + Durable Objects.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
